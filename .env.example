# ─── AI / Search APIs ─────────────────────────────────────────────────────────
# Google Gemini — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# SerpAPI — get from https://serpapi.com/dashboard
SERP_API_KEY=your_serp_api_key_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get both from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service-role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Upstash Redis (rate-limiting & API caching) ──────────────────────────────
# Get from: https://console.upstash.com > your database > REST API
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here
